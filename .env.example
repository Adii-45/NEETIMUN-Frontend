# ─────────────────────────────────────────────────────────────────────────
#  Google Sheets Registration Integration
# ─────────────────────────────────────────────────────────────────────────
#
#  Copy this file to `.env.local` and fill in the values below.
#
#  All variables use the NEXT_PUBLIC_ prefix because the browser submits the
#  registration directly to the Google Apps Script Web App (there is no custom
#  backend). NEXT_PUBLIC_ values are embedded into the client bundle at build
#  time, so only put non-sensitive values here — the Spreadsheet ID and the
#  Apps Script URL are append-only endpoints, not secrets.

# The Spreadsheet ID from your Google Sheet URL:
#   https://docs.google.com/spreadsheets/d/<THIS_IS_THE_ID>/edit
NEXT_PUBLIC_GOOGLE_SPREADSHEET_ID=

# The Apps Script Web App deployment URL (ends with /exec):
#   https://script.google.com/macros/s/AKfyc.../exec
NEXT_PUBLIC_GOOGLE_APPS_SCRIPT_URL=

# The tab (sheet) name rows are appended to. Defaults to "Registrations".
NEXT_PUBLIC_REGISTRATION_SHEET_NAME=Registrations
